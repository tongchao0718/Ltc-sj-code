/AIEP-WEB/build/vite.ai-smart-crm-admin.config.js @YOUR-ORG/team-crm @YOUR-ORG/team-leads
/AIEP-WEB/build/ai-smart-crm-admin.html @YOUR-ORG/team-crm @YOUR-ORG/team-leads

# ── 营销系统 Demo ───────────────────────────────────
/AIEP-WEB/src/apps/marketing-demo/ @YOUR-ORG/team-marketing @YOUR-ORG/team-leads
