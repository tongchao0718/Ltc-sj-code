/AIEP-WEB/build/vite.marketing-demo.config.js @YOUR-ORG/team-marketing @YOUR-ORG/team-leads
/AIEP-WEB/build/marketing-demo.html @YOUR-ORG/team-marketing @YOUR-ORG/team-leads

# ── 框架文档与权限配置 ─────────────────────────────
/核心文档/框架核心文档/ @YOUR-ORG/framework-maintainers
