{
  "name": "aiep-web",
  "private": true,
  "version": "1.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:sample-app": "vite build --config build/vite.sample-app.config.js",
    "dev:sample-app": "vite --config build/vite.sample-app.config.js",
    "update": "node src/scripts/update.js",
    "rollback": "node src/scripts/rollback.js",
    "create-update-package": "node src/scripts/create-update-package.js",
    "version:echo": "node -e \"console.log('Current version:', process.env.npm_package_version)\"",
    "install-deps": "node src/tools/install-deps.js",
    "test": "vitest run --config vite.config.test.js",
    "test:watch": "vitest watch --config vite.config.test.js",
    "test:coverage": "vitest run --config vite.config.test.js --coverage"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.6",
    "arco-design-vue": "^2.69.4",
    "axios": "^1.7.9",
    "js-cookie": "^3.0.5",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "marked": "^14.1.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.1",
    "vite": "^6.0.5",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^3.0.1"
  }
}