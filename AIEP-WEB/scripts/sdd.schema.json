{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aiep-dev.local/schemas/sdd.json",
  "title": "AIEP SDD JSON",
  "type": "object",
  "required": ["sdd_id", "version", "owner", "app_code", "in_scope", "out_of_scope", "api_contracts", "acceptance"],
  "properties": {
    "sdd_id": { "type": "string", "pattern": "^SDD-" },
    "version": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "app_code": { "type": "string", "minLength": 1 },
    "track": { "type": "string", "enum": ["full", "fast", "fast_track"] },
    "stage": { "type": "string" },
    "in_scope": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "out_of_scope": { "type": "array", "items": { "type": "string" } },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-" },
          "name": { "type": "string" },
          "priority": { "type": "string" },
          "acceptance_ref": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "api_contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "method"],
        "properties": {
          "id": { "type": "string", "pattern": "^API-" },
          "path": { "type": "string", "pattern": "^/" },
          "method": { "type": "string" },
          "request": { "type": "object" },
          "response": { "type": "object" },
          "errors": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "state_machine": { "type": "array" },
    "data_model": { "type": "array" },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string", "pattern": "^AT-" },
          "given": { "type": "string", "minLength": 1 },
          "when": { "type": "string", "minLength": 1 },
          "then": { "type": "string", "minLength": 1 },
          "priority": { "type": "string" }
        }
      }
    },
    "exception_strategy": { "type": "array" },
    "rollback_plan": { "type": "string" }
  },
  "additionalProperties": true
}
