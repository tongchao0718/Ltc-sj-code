  "data_model": [
    { "entity": "crm_user", "primary_key": "user_id", "description": "独立账号用户" },
    { "entity": "crm_role", "primary_key": "role_id", "description": "角色权限" },
    { "entity": "crm_organization", "primary_key": "org_id", "description": "组织树" },
    { "entity": "crm_customer", "primary_key": "customer_id", "description": "客户主数据" },
    { "entity": "crm_lead", "primary_key": "lead_id", "description": "线索" },
    { "entity": "crm_contact", "primary_key": "contact_id", "description": "联系人" },
    { "entity": "crm_opportunity", "primary_key": "opportunity_id", "description": "商机" },
    { "entity": "crm_activity", "primary_key": "activity_id", "description": "跟进活动" },
    { "entity": "crm_ai_score", "primary_key": "score_id", "description": "AI意向评分" },
    { "entity": "crm_ai_suggestion", "primary_key": "suggestion_id", "description": "AI跟进建议" },
    { "entity": "crm_config_stage", "primary_key": "config_id", "description": "销售阶段配置" },
    { "entity": "crm_import_batch", "primary_key": "batch_id", "description": "导入批次" },
    { "entity": "crm_audit_log", "primary_key": "log_id", "description": "审计日志" }
  ],
  "state_machine": [
    { "page": "AppHomePage", "states": ["loading", "success", "empty", "error"] },
    { "page": "CustomerListPage", "states": ["loading", "success", "empty", "error"] },
    { "page": "OpportunityDetailPage", "states": ["idle", "submitting", "success", "error"] },
    { "page": "AiAssistantSheet", "states": ["idle", "streaming", "done", "error"] },
    { "page": "AdminImportPage", "states": ["pending", "processing", "done", "failed"] },
    { "page": "LoginPage", "states": ["idle", "submitting", "success", "error"] }
  ],
  "exception_strategy": [
    { "type": "network_offline", "action": "save_draft_queue", "user_hint": "网络不可用，已保存草稿" },
    { "type": "timeout", "action": "show_retry", "user_hint": "请求超时，请重试" },
    { "type": "http_401", "action": "redirect_login", "user_hint": "登录已过期" },
    { "type": "http_403", "action": "show_forbidden", "user_hint": "无访问权限" },
    { "type": "ai_quota", "code": 1006, "action": "block_ai", "user_hint": "今日AI次数已用完" },
    { "type": "import_row_error", "code": 1007, "action": "download_error_report", "user_hint": "部分行导入失败" }
  ],
  "acceptance": [
    { "id": "AT-01", "given": "销售已登录且有负责商机", "when": "打开APP首页", "then": "KPI与待办列表渲染且可跳转详情", "priority": "P0" },
    { "id": "AT-02", "given": "销售角色数据权限为SELF", "when": "查询客户列表", "then": "仅返回本人负责客户", "priority": "P0" },
    { "id": "AT-03", "given": "公海池有待领取线索", "when": "销售执行领取", "then": "负责人更新成功并产生通知", "priority": "P0" },
    { "id": "AT-04", "given": "客户已有主联系人", "when": "设置另一联系人为主联系人", "then": "原主联系人自动取消且仅一名主联系人", "priority": "P0" },
    { "id": "AT-05", "given": "商机处于阶段A且规则允许", "when": "切换至阶段B", "then": "阶段更新且活动时间线新增记录", "priority": "P0" },
    { "id": "AT-06", "given": "用户在客户详情页", "when": "提交快速跟进", "then": "活动记录入库并出现在时间线", "priority": "P0" },
    { "id": "AT-07", "given": "赢单商机存在", "when": "登记合同", "then": "合同与商机关联成功", "priority": "P1" },
    { "id": "AT-08", "given": "客户有跟进与商机行为", "when": "查看意向评分", "then": "展示分数等级及Top3影响因子", "priority": "P0" },
    { "id": "AT-09", "given": "用户在客户详情", "when": "唤起AI助手生成话术", "then": "返回可复制内容且记录采纳状态", "priority": "P0" },
    { "id": "AT-10", "given": "存在超期未跟进商机", "when": "查看AI建议", "then": "可采纳或忽略并更新建议状态", "priority": "P0" },
    { "id": "AT-11", "given": "团队有历史商机数据", "when": "打开销售预测", "then": "展示预测区间与关键假设", "priority": "P1" },
    { "id": "AT-12", "given": "知识库有FAQ条目", "when": "APP发起问答", "then": "返回答案并附带引用来源", "priority": "P1" },
    { "id": "AT-13", "given": "客服收到工单", "when": "处理并关闭", "then": "工单状态闭环且客户时间线可见", "priority": "P1" },
    { "id": "AT-14", "given": "上传清晰名片图片", "when": "执行OCR识别", "then": "姓名手机公司等字段预填可编辑", "priority": "P0" },
    { "id": "AT-15", "given": "用户有本周业务数据", "when": "打开简报", "then": "核心指标与迷你漏斗展示正确", "priority": "P0" },
    { "id": "AT-16", "given": "用户修改推送开关", "when": "保存设置", "then": "设置持久化且推送行为随之变化", "priority": "P0" },
    { "id": "AT-17", "given": "收到跟进提醒推送", "when": "点击通知", "then": "APP直达对应商机详情页", "priority": "P0" },
    { "id": "AT-18", "given": "执行APP双端构建", "when": "安装并启动", "then": "登录后核心Tab页面可访问", "priority": "P0" },
    { "id": "AT-19", "given": "管理员上传合法导入模板", "when": "执行导入", "then": "生成成功失败统计且可下载错误明细", "priority": "P0" },
    { "id": "AT-20", "given": "管理员创建销售账号", "when": "该用户APP登录", "then": "仅访问权限范围内业务数据", "priority": "P0" },
    { "id": "AT-21", "given": "执行 build:ai-smart-crm-admin", "when": "浏览器独立访问管理台", "then": "登录后仪表盘页面正常渲染", "priority": "P0" },
    { "id": "AT-22", "given": "主应用 npm run dev 且 validate:sub-app-registry 通过", "when": "应用中心进入或访问 /ai-smart-crm-admin/dashboard", "then": "嵌入主应用顶栏下侧栏与仪表盘正常；首页应用数量为 3", "priority": "P0" }
  ],
  "rollback_plan": "发布后P0/P1故障30分钟内回滚API与Web静态资源；APP强制最低兼容版本"
}
