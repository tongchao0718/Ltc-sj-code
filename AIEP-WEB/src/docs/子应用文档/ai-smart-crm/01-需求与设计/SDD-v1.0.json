      "story": "作为运营管理员，我希望在Web配置销售阶段以便APP按统一规则作业",
      "requirement_ref": "SA-19/Web管理台",
      "release_slice": "MVP",
      "acceptance_ref": ["AT-19"],
      "acceptance_standard": "Given发布阶段配置 When APP新建商机 Then 默认阶段生效"
    }
