{
  "sdd_id": "SDD-20260606-MD-001",
  "version": "1.0.0",
  "owner": "AI产品组",
  "stage": "build",
  "app_code": "marketing-demo",
  "feature_name": "售电公司营销分析Demo",
  "requirement_ref": "《01-需求说明书》V1.1-demo",
  "updated_at": "2026-06-06",
  "track": "demo",
  "in_scope": [
    "data-integration-three-sources",
    "nine-dimension-query",
    "four-dimension-analysis",
    "business-profile",
    "one-click-report",
    "settlement-agreement-lifecycle",
    "performance-control",
    "mock-api-localStorage",
    "standalone-and-embed-build"
  ],
  "out_of_scope": [
    "production-tianyancha-api",
    "production-trade-center-api",
    "marketing-2-platform-nesting-final",
    "sms-gateway",
    "ocr-engine",
    "mobile-app",
    "workflow-engine"
  ],
  "tech_stack": {
    "frontend": "Vue3 + Vue Router + marketing-demo scoped CSS (YXUI)",
    "data_layer": "mock/api.js + marketingStore (localStorage persist)",
    "charts": "ECharts",
    "build": "vite build:marketing-demo + main app embed"
  },
  "business_goal": "售电公司全链路 Demo：接入→查询→分析→画像→报告→协议→履约，Mock 可替换契约",
  "success_metrics": [
    "md_1_to_23_full_delivery",
    "c1_to_c6_closure_per_requirement",
    "first_screen_3s_mock",
    "validate_sub_app_registry_pass",
    "at_22_embed_pass"
  ],
  "roles": [
    { "role": "营销业务人员", "permissions": ["query_read", "export"], "data_scope": "ALL" },
    { "role": "数据分析人员", "permissions": ["analysis_read", "profile_edit", "report_generate"], "data_scope": "ALL" },
    { "role": "协议管理员", "permissions": ["agreement_crud", "agreement_audit"], "data_scope": "ALL" },
    { "role": "履约管理员", "permissions": ["performance_manage", "assessment_run"], "data_scope": "ALL" },
    { "role": "系统管理员", "permissions": ["integration_sync", "governance_config"], "data_scope": "ALL" }
  ],
  "features": [
    { "id": "F-01", "name": "data-integration", "requirement_ref": "MD-1", "priority": "P0", "acceptance_ref": ["AT-01", "AT-02"] },
    { "id": "F-02", "name": "nine-dimension-query", "requirement_ref": "MD-2~10", "priority": "P0", "acceptance_ref": ["AT-03"] },
    { "id": "F-03", "name": "multi-analysis", "requirement_ref": "MD-11~15", "priority": "P0", "acceptance_ref": ["AT-04"] },
    { "id": "F-04", "name": "business-profile", "requirement_ref": "MD-16", "priority": "P0", "acceptance_ref": ["AT-05"] },
    { "id": "F-05", "name": "one-click-report", "requirement_ref": "MD-17", "priority": "P0", "acceptance_ref": ["AT-06"] },
    { "id": "F-06", "name": "settlement-agreement", "requirement_ref": "MD-18~20", "priority": "P0", "acceptance_ref": ["AT-07"] },
    { "id": "F-07", "name": "performance-control", "requirement_ref": "MD-21~23", "priority": "P0", "acceptance_ref": ["AT-08"] },
    { "id": "F-08", "name": "main-app-integration", "requirement_ref": "独立+嵌入", "priority": "P0", "acceptance_ref": ["AT-22"] }
  ],
  "api_contracts": [
    { "id": "API-01", "method": "POST", "path": "/mock/marketing-demo/integration/sync", "function": "syncIntegration", "description": "触发三源同步并写 syncLogs" },
    { "id": "API-02", "method": "GET", "path": "/mock/marketing-demo/companies/query", "function": "queryCompanies", "description": "企业主数据分页查询" },
    { "id": "API-03", "method": "GET", "path": "/mock/marketing-demo/list/{dataset}", "function": "queryList", "description": "九维数据集分页筛选" },
    { "id": "API-04", "method": "POST", "path": "/mock/marketing-demo/export", "function": "exportMock", "description": "导出 xlsx/pdf Mock" },
    { "id": "API-05", "method": "GET", "path": "/mock/marketing-demo/business-info/{companyId}", "function": "getBusinessInfoTabs", "description": "工商 14 类 Tab" },
    { "id": "API-06", "method": "PUT", "path": "/mock/marketing-demo/governance", "function": "saveGovernance", "description": "接入治理配置持久化" },
    { "id": "API-07", "method": "PUT", "path": "/mock/marketing-demo/performance/expiry-days", "function": "saveExpiryDays", "description": "保函临期天数" },
    { "id": "API-08", "method": "PUT", "path": "/mock/marketing-demo/agreements/{id}/status", "function": "updateAgreementStatus", "description": "协议四环节状态流转" },
    { "id": "API-09", "method": "POST", "path": "/mock/marketing-demo/reports/generate", "function": "generateReport", "description": "一键报告生成" },
    { "id": "API-10", "method": "POST", "path": "/mock/marketing-demo/assessment/{companyId}", "function": "runAssessment", "description": "履约能力六维评估" },
    { "id": "API-11", "method": "CRUD", "path": "/mock/marketing-demo/crud/{apiKey}", "function": "crudList|crudCreate|crudUpdate|crudDelete", "description": "通用 CRUD（模板/画像等）" }
  ],
  "state_machine": [
    {
      "id": "SM-01",
      "name": "agreement-lifecycle",
      "states": ["draft", "pending", "active", "terminated"],
      "transitions": [
        { "from": "draft", "to": "pending", "action": "submit" },
        { "from": "pending", "to": "active", "action": "approve" },
        { "from": "pending", "to": "draft", "action": "reject" },
        { "from": "active", "to": "terminated", "action": "terminate" }
      ]
    },
    {
      "id": "SM-02",
      "name": "performance-process",
      "states": ["init", "review", "handle", "verify", "close"],
      "transitions": [
        { "from": "init", "to": "review", "action": "start" },
        { "from": "review", "to": "handle", "action": "assign" },
        { "from": "handle", "to": "verify", "action": "complete" },
        { "from": "verify", "to": "close", "action": "confirm" }
      ]
    },
    {
      "id": "SM-03",
      "name": "query-page",
      "states": ["idle", "loading", "success", "empty", "error"],
      "transitions": [
        { "from": "idle", "to": "loading", "action": "search" },
        { "from": "loading", "to": "success", "action": "data_ok" },
        { "from": "loading", "to": "empty", "action": "no_data" },
        { "from": "loading", "to": "error", "action": "fail" },
        { "from": "error", "to": "loading", "action": "retry" }
      ]
    }
  ],
  "acceptance": [
    { "id": "AT-01", "given": "接入总览页", "when": "点击立即同步", "then": "syncLogs 追加且 integration 状态更新", "priority": "P0", "feature_ref": "F-01" },
    { "id": "AT-02", "given": "工商信息页", "when": "打开企业详情", "then": "14 类 Tab 均有样例数据", "priority": "P0", "feature_ref": "F-01" },
    { "id": "AT-03", "given": "任一查询页", "when": "筛选并提交", "then": "四态正确且 exportMock 可触发", "priority": "P0", "feature_ref": "F-02" },
    { "id": "AT-04", "given": "分析看板", "when": "点击钻取", "then": "跳转查询页或打开明细弹窗", "priority": "P0", "feature_ref": "F-03" },
    { "id": "AT-05", "given": "画像详情", "when": "增删标签", "then": "profiles 持久化且历史轴更新", "priority": "P0", "feature_ref": "F-04" },
    { "id": "AT-06", "given": "报告生成", "when": "选择模板生成", "then": "返回 fileName 且可溯源跳转", "priority": "P0", "feature_ref": "F-05" },
    { "id": "AT-07", "given": "协议生命周期", "when": "审核通过/驳回", "then": "状态按 SM-01 流转且留痕", "priority": "P0", "feature_ref": "F-06" },
    { "id": "AT-08", "given": "履约临期配置", "when": "修改临期天数", "then": "expiryDays 持久化且列表过滤生效", "priority": "P0", "feature_ref": "F-07" },
    { "id": "AT-22", "given": "主应用 dev 且 validate:sub-app-registry 通过", "when": "访问 /marketing-demo/dashboard", "then": "沉浸顶栏+子应用壳层+目标页正常", "priority": "P0", "feature_ref": "F-08" }
  ]
}
