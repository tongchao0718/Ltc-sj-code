{
  "name": "ltc-demo",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd AIEP-WEB && vite --config vite.config.js",
    "build": "cd AIEP-WEB && vite build --config vite.config.js",
    "preview": "cd AIEP-WEB && vite preview --config vite.config.js",
    "build:sample-app": "cd AIEP-WEB && vite build --config build/vite.sample-app.config.js",
    "dev:sample-app": "cd AIEP-WEB && vite --config build/vite.sample-app.config.js",
    "build:power-fee-protocol-check": "cd AIEP-WEB && vite build --config build/vite.power-fee-protocol-check.config.js",
    "dev:power-fee-protocol-check": "cd AIEP-WEB && vite --config build/vite.power-fee-protocol-check.config.js",
    "update": "node AIEP-WEB/src/scripts/update.js",
    "rollback": "node AIEP-WEB/src/scripts/rollback.js",
    "create-update-package": "node AIEP-WEB/src/scripts/create-update-package.js",
    "version:echo": "node -e \"console.log('Current version:', process.env.npm_package_version)\"",
    "install-deps": "node AIEP-WEB/src/tools/install-deps.js",
    "test": "cd AIEP-WEB && vitest run --config vite.config.test.js",
    "test:watch": "cd AIEP-WEB && vitest watch --config vite.config.test.js",
    "test:coverage": "cd AIEP-WEB && vitest run --config vite.config.test.js --coverage",
    "server:dev": "cd AIEP-SERVER && npm run dev",
    "server:start": "cd AIEP-SERVER && npm start",
    "server:test": "cd AIEP-SERVER && npm test",
    "server:install": "cd AIEP-SERVER && npm install",
    "install:all": "npm install && cd AIEP-SERVER && npm install"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.57.0",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "axios": "^1.14.0",
    "china-map-geojson": "^1.0.4",
    "echarts": "^5.6.0",
    "less": "^4.6.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "jsdom": "^29.0.2",
    "pinia-plugin-persistedstate": "^4.7.1",
    "terser": "^5.46.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
